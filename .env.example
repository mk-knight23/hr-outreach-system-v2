# HR Outreach System v2 - Environment Configuration

# Google Sheets Spreadsheet ID
# Get this from the URL: https://docs.google.com/spreadsheets/d/{SPREADSHEET_ID}/edit
SPREADSHEET_ID=your_spreadsheet_id_here

# gws CLI Authentication
# Path to service account JSON key file (for CI/automation)
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# Or use interactive auth for local development:
# Run: gws auth login

# GitHub Actions Secrets (set these in your repo settings):
# - GWS_CREDENTIALS: Base64-encoded service account JSON
# - SPREADSHEET_ID: Your Google Sheet ID
# - SLACK_WEBHOOK_URL: (Optional) For failure notifications

# Rate Limiting (configured in config.py)
# MAX_EMAILS_PER_DAY=20
# MAX_EMAILS_PER_HOUR=5
