# Environment Configuration

# Gmail Configuration (Google Workspace CLI)
GMAIL_USER=mk.knight970@gmail.com

# gws CLI is already authenticated via OAuth
# No password needed - uses token-based auth

# Database
DB_PATH=./database/contacts.db

# Email Limits
DAILY_EMAIL_LIMIT=100
HOURLY_EMAIL_LIMIT=20

# Send Schedule (IST)
SEND_START_HOUR=9
SEND_END_HOUR=18

# Target Job Criteria
TARGET_ROLE=AI Engineer
TARGET_LOCATION=India
TARGET_EXPERIENCE=2-6 years

# API Keys (if needed for enrichment)
# LINKEDIN_API_KEY=
# HUNTER_API_KEY=

# Logging
LOG_LEVEL=info
LOG_FILE=./logs/outreach.log

# GitHub
GITHUB_REPO=mk-knight23/hr-outreach-system-v2

# Features
ENABLE_TRACKING=true
ENABLE_ANALYTICS=true
AUTO_FOLLOW_UP=true
FOLLOW_UP_DAYS=3,7,14
